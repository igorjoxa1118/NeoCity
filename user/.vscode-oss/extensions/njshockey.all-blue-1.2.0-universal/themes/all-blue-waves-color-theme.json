			"settings": { "foreground": "#DBD59D" }
		},
		{
			"name": "Invalid",
			"scope": ["invalid", "invalid.illegal"],
			"settings": { "foreground": "#FF7566" }
		},
		{
			"name": "Inserted",
			"scope": ["markup.inserted"],
			"settings": { "foreground": "#FEF08A" }
		},
		{
			"name": "Deleted",
			"scope": ["markup.deleted"],
			"settings": { "foreground": "#FF7566" }
		},
		{
			"name": "Changed",
			"scope": ["markup.changed"],
			"settings": { "foreground": "#85A1F2" }
		},
		{
			"name": "Regular Expressions",
			"scope": ["string.regexp"],
			"settings": { "foreground": "#0BDA51" }
		},
		{
			"name": "Escape Characters",
			"scope": ["constant.character.escape"],
			"settings": { "foreground": "#079BF5" }
		},
		{
			"name": "URL",
			"scope": ["*url*", "*link*", "*uri*"],
