#-------------------------------
## Режим редактирование отступов
 Win+Alt+g mode "Wine_gaps" # Войти в режим отступов.

mode "Wine_gaps" {
         o      mode "Wine_gaps_outer"
         i      mode "Wine_gaps_inner"
         Return mode "default"
         Escape mode "default"
}

mode "Wine_gaps_inner" {
         plus  gaps inner current plus 5
         minus gaps inner current minus 5
         0     gaps inner current set 0

         Alt+plus  gaps inner all plus 5
         Alt+minus gaps inner all minus 5
         Alt+0     gaps inner all set 0

         Return mode "default"
         Escape mode "default"
}
mode "Wine_gaps_outer" {
         plus  gaps outer current plus 5
         minus gaps outer current minus 5
         0     gaps outer current set 0

         Alt+plus  gaps outer all plus 5
         Alt+minus gaps outer all minus 5
         Alt+0     gaps outer all set 0

         Return mode "default"
         Escape mode "default"
}
