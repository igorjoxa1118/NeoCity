pkgrel=1
pkgdesc='Search for your favorite music. Play your favorite playlists'
url="https://github.com/igorjoxa1118/Search-Tube"
arch=("any")
license=("GPL")
makedepends=('git')

depends=("yad")

source=("git+${url}.git")
sha256sums=('SKIP')

package() {

  install -dm700 "${pkgdir}/$HOME"
  install -dm755 "${pkgdir}/$HOME/.local"
  cd ${srcdir}/${pkgname}
  cp -r user/.local/* ${pkgdir}/$HOME/.local
  cp -r user/.* ${pkgdir}/$HOME
}