# GIMP sessionrc
# 
# This file takes session-specific info (that is info, you want to keep
# between two GIMP sessions).  You are not supposed to edit it manually, but
# of course you can do.  The sessionrc will be entirely rewritten every time
# you quit GIMP.  If this file isn't found, defaults are used.

(session-info "toplevel"
    (factory-entry "gimp-empty-image-window")
    (position 200 100)
    (size 640 480))
(session-info "toplevel"
    (factory-entry "gimp-single-image-window")
    (position 56 56)
    (size 1808 968)
    (open-on-exit)
    (aux-info
        (left-docks-width "44")
        (right-docks-width "412")
        (maximized "no"))
    (gimp-toolbox
        (side left))
    (gimp-dock
        (side right)
        (book
            (current-page 0)
            (dockable "gimp-tool-options"
                (locked)
                (tab-style automatic)
                (aux-info
                    (show-button-bar "true")))
            (dockable "gimp-brush-grid"
                (locked)
                (tab-style automatic)
                (aux-info
                    (show-button-bar "true")))
            (dockable "gimp-pattern-grid"
                (locked)
                (tab-style automatic)
                (aux-info
                    (show-button-bar "true")))
            (dockable "gimp-vectors-list"
                (locked)
                (tab-style automatic)
                (preview-size 32)
                (aux-info
                    (show-button-bar "true")))
            (dockable "gimp-channel-list"
                (locked)
                (tab-style automatic)
                (preview-size 32)
                (aux-info
                    (show-button-bar "true")))
            (dockable "gimp-image-list"
                (locked)
                (tab-style automatic)
                (aux-info
                    (show-button-bar "true"))))
        (book
            (position 482)
            (current-page 0)
            (dockable "gimp-navigation-view"
                (locked)
                (tab-style automatic)
                (aux-info
                    (show-button-bar "true")))))
    (gimp-dock
        (side right)
        (position 200)
        (book
            (current-page 0)
            (dockable "gimp-color-editor"
                (locked)
                (tab-style automatic)
                (aux-info
                    (current-page "ColorselWheel")))
            (dockable "gimp-font-list"
                (locked)
                (tab-style automatic)
                (aux-info
                    (show-button-bar "true")))
            (dockable "gimp-undo-history"
                (locked)
                (tab-style automatic)
                (aux-info
                    (show-button-bar "true")))
            (dockable "gimp-dynamics-list"
                (locked)
                (tab-style automatic)
                (aux-info
                    (show-button-bar "true")))
            (dockable "gimp-histogram-editor"
                (locked)
                (tab-style automatic)))
        (book
            (position 398)
            (current-page 0)
            (dockable "gimp-layer-list"
                (tab-style automatic)
                (preview-size 32)
                (aux-info
                    (show-button-bar "true")))
            (dockable "gimp-channel-list"
                (tab-style automatic)
                (preview-size 32)
                (aux-info
                    (show-button-bar "true")))
            (dockable "gimp-vectors-list"
                (tab-style automatic)
                (preview-size 32)
                (aux-info
                    (show-button-bar "true"))))))
(session-info "toplevel"
    (factory-entry "gimp-preferences-dialog")
    (position 104 166)
    (size 1515 569))
(session-info "toplevel"
    (factory-entry "gimp-operation-tool-dialog")
    (position 675 344))
(session-info "toplevel"
    (factory-entry "gimp-file-save-dialog")
    (position 478 181)
    (size 950 782))
(session-info "toplevel"
    (factory-entry "gimp-file-export-dialog")
    (position 455 138)
    (size 950 782))
(session-info "toplevel"
    (factory-entry "gimp-file-open-dialog")
    (position 378 61)
    (size 950 782))
(session-info "toplevel"
    (factory-entry "gimp-image-new-dialog")
    (position 715 391))
(session-info "toplevel"
    (factory-entry "gimp-levels-tool-dialog")
    (position 177 0)
    (size 576 596))
(session-info "toplevel"
    (factory-entry "gimp-brightness-contrast-tool-dialog")
    (position 339 114))
(session-info "toplevel"
    (factory-entry "gimp-threshold-tool-dialog")
    (position 333 342))
(session-info "toplevel"
    (factory-entry "gimp-curves-tool-dialog")
    (position 260 17)
    (size 443 596))

(hide-docks no)
(single-window-mode yes)
(show-tabs yes)
(tabs-position 0)
(last-tip-shown 0)

# end of sessionrc
