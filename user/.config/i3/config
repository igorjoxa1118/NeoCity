### --- Подключение отдельных файлов конфигураций i3

include "$HOME/.config/i3/config.d/autostart"
include "$HOME/.config/i3/config.d/colors"
include "$HOME/.config/i3/config.d/fonts"
include "$HOME/.config/i3/config.d/keybinds"
include "$HOME/.config/i3/config.d/rules"

set $mod Mod4
set $mod1 Mod1
set $i3_scripts ~/.config/i3/src
set $i3_configd ~/.config/i3/config.d

# или new_window normal или new_window none
new_window pixel 1
# или new_float normal new_float none
new_float pixel 1

### --- Этот параметр реагирует на рамки всех окон. Так же есть параметр hide_edge_borders both
hide_edge_borders smart

# smart_gaps on
smart_borders on

set $default_gaps_inner 28
set $default_gaps_outer 28
gaps inner $default_gaps_inner
gaps outer $default_gaps_outer

set $ws-right "$(( $( i3-msg -t get_workspaces | jq '.[] | select(.focused).num' ) + 1))";
set $ws-left "$(( $( i3-msg -t get_workspaces | jq '.[] | select(.focused).num' ) - 1))";

floating_modifier $mod

### --- Определение имен, для рабочих пространств по умолчанию/
### --- Для которых существуют привязки клавиш в файле "$HOME/.config/i3/keybinds".

set $ws1 1
set $ws2 2
set $ws3 3
set $ws4 4
set $ws5 5
set $ws6 6
set $ws7 7
set $ws8 8
set $ws9 9
set $ws10 10